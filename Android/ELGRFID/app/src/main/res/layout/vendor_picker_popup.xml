<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/vendor_picker_popup_bg"
    android:orientation="vertical">

    <ListView
        android:id="@+id/vendor_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:paddingTop="4dp"
        android:scrollbars="vertical" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC" />

    <LinearLayout
        android:id="@+id/vendor_popup_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/vendor_add_button"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:contentDescription="@string/add_filament"
            app:srcCompat="@drawable/twotone_add_24"
            app:tint="@color/primary_brand" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/vendor_select_button"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/select"
            android:textAllCaps="false"
            android:textColor="@color/primary_brand"
            android:textSize="14sp" />

        <Button
            android:id="@+id/vendor_edit_button"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/edit"
            android:textAllCaps="false"
            android:textColor="@color/primary_brand"
            android:textSize="14sp" />

        <Button
            android:id="@+id/vendor_remove_button"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/remove"
            android:textAllCaps="false"
            android:textColor="@color/primary_brand"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>